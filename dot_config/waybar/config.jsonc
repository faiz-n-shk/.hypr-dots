// -*- mode: jsonc -*-
{
    "layer": "middle",
    "position": "top",
    "margin-top": 5,
    "spacing": 4,

  // Modules
    "modules-left": [
    "group/left-pill",
    "hyprland/window"
    ],
    "modules-center": [
    "clock",
    "custom/separatordot",
    "hyprland/workspaces",
    "custom/separatordot",
    "clock#right"
  ],
    "modules-right": [
    "custom/network",
    "battery",
    "tray",
    "custom/notification"
    ],

  // Modules configuration
  "custom/separatordot": {
    "format": "â€¢",
    "tooltip": false
},
  "group/left-pill": {
    "orientation": "horizontal",
    "modules": [
        "pulseaudio",
        "backlight"
    ]
},
  "hyprland/window": {
    "format": "{class}",
    "separate-outputs": true,
},
  "backlight": {
  	"device": "intel_backlight",
	  "format": "{icon}{percent}%",
	  "format-icons": ["َ°ƒ›", "َ°ƒœ", "َ°ƒ‍ ", "َ°ƒ‌ ", "َ°ƒں ", "َ°ƒ  "]
},
  "custom/network": {
    "exec": "nmcli -t -f TYPE,NAME,DEVICE connection show --active | awk -F: '$1==\"802-11-wireless\"{printf \"<span rise=\\\"1000\\\">\\uF0928</span> %s\\n\", $2; exit} $1==\"802-3-ethernet\"{printf \"<span rise=\\\"100\\\">\\uF0200</span> %s\\n\", $2; exit}'; [[ ${PIPESTATUS} -eq 0 ]] || echo '<span rise=\\\"1500\\\">\\uF092D</span> Disconnected'",
    "interval": 5,
    "format": "{}",
    "tooltip": false
},
"pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon}ïٹ” {volume}%",
    "format-muted": "َ°‌ں",
    "format-icons": {
        "headphone": "ï€¥",
        "hands-free": "ï–گ",
        "headset": "ï–گ",
        "phone": "ï‚•",
        "phone-muted": "î´—",
        "portable": "ï‚•",
        "car": "ï†¹",
        "default": ["َ°•؟", "َ°–€", "َ°–€", "َ°•¾"]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"]
},
  "clock":{
    "format": "{:%H:%M}",
    "tooltip": true,
    "tooltip-format": "<big>{:%I:%M %p}</big>\n<tt>{calendar}</tt>"
  },
  "clock#right":{
    "format": "{:%a, %d/%m/%y}",
    "tooltip": true,
    "tooltip-format": "<big>{:%Y %B %d}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "warp-on-scroll": false,
    "format": "{icon}",
    "format-icons": {
        "1": "ن¸€",
        "2": "ن؛Œ",
        "3": "ن¸‰",
        "4": "ه››",
        "5": "ن؛”",
        "6": "ه…­",
        "7": "ن¸ƒ",
        "8": "ه…«",
        "9": "ن¹‌",
        "10": "ن»€",
    }
},
	"tray": {
		"icon-size": 16,
		"spacing": 12,
		"cursor": true
},
  "battery": {
    "bat": "BAT1",
    "interval": "10",
    "format": "{capacity}% {icon}",
    "format-icons": {
        "default": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "charging": ["َ°¢ں", "َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"]
    }
},
  "custom/notification": {
    "tooltip": false,
    "format": "{} {icon}",
    "format-icons": {
        "notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
        "none": "ï‚¢",
        "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
        "dnd-none": "ï‡·",
        "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
        "inhibited-none": "ï‚¢",
        "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
        "dnd-inhibited-none": "ï‡·"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "sleep 0.1 && swaync-client -d -sw",
    "escape": true
  }
}



