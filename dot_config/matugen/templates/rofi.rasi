* {
    background:          {{colors.surface.default.hex}};
    background-tint:     {{colors.primary_container.default.hex}}80;
    background-alt:      {{colors.surface_container_high.default.hex}};
    foreground:          {{colors.on_surface.default.hex}};
    selected:            {{colors.primary_container.default.hex}};
    search-tint:         {{colors.on_surface.default.hex}}50;
    hover-tint:          {{colors.on_surface.default.hex}}50;
}
