#!/usr/bin/env bash

# Hardcoded target state that the script updates inside itself
CURRENT_STATE="true"

# 1. Map the state to Rofi menu text and the next execution state
if [ "$CURRENT_STATE" = "true" ]; then
  menu_text="Disable Cursor Anims"
  next_state="false"
else
  menu_text="Enable Cursor Anims"
  next_state="true"
fi

# 2. Present the single contextual option to the user
chosen=$(echo -e "$menu_text" | rofi -dmenu -p "Quick Menu:")

# 3. Apply changes and modify the script's own internal flag for next time
if [ "$chosen" = "$menu_text" ]; then
  hyprctl eval "hl.config({ plugin = { dynamic_cursors = { enabled = $next_state }  } })"
  sed -i "s/CURRENT_STATE=\"$CURRENT_STATE\"/CURRENT_STATE=\"$next_state\"/" "$0"
fi
