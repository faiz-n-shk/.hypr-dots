#!/usr/bin/env bash

WALLPAPER="$1"
if [ -z "$WALLPAPER" ]; then
  echo "Error: No wallpaper path provided."
  exit 1
fi

transition_angle=("0" "90" "180" "270")
transition_list=("grow" "wipe" "outer" "center")

CHOSEN_ANGLE=${transition_angle[$RANDOM % ${#transition_angle[@]}]}
CHOSEN_TYPE=${transition_list[$RANDOM % ${#transition_list[@]}]}

# Python monochrome check
IS_GRAYSCALE=false
if command -v python3 &>/dev/null; then
  if python3 -c "
import sys
from PIL import Image
img = Image.open('$WALLPAPER').convert('RGB').resize((50, 50))
pixels = list(img.getdata())
r, g, b = zip(*pixels)
# Calculate standard deviation across RGB channels to identify color presence
variance = sum(abs(r[i]-g[i]) + abs(g[i]-b[i]) + abs(b[i]-r[i]) for i in range(len(pixels))) / len(pixels)
if variance < 15.0:
    print('true')
" 2>/dev/null | grep -q "true"; then
    IS_GRAYSCALE=true
  fi
fi

# Compile matugen templates
if [ "$IS_GRAYSCALE" = true ]; then
  matugen -c "$HOME/.config/matugen/config.toml" image "$WALLPAPER" --type scheme-monochrome --mode dark --source-color-index 0
else
  matugen -c "$HOME/.config/matugen/config.toml" image "$WALLPAPER" --mode dark --source-color-index 0
fi

# Trigger SwayNC Reload
if command -v swaync-client &>/dev/null; then
  swaync-client -rs &>/dev/null &
fi

# Reload Kitty
if pgrep -x "kitty" >/dev/null; then
  kill -SIGUSR1 $(pgrep -x kitty)
fi

# Signal Waybar Reload
if pgrep -x "waybar" >/dev/null; then
  kill -SIGUSR2 $(pgrep -x waybar)
fi

# Update the wallpaper
if pgrep -x "awww-daemon" >/dev/null; then
  awww img "$WALLPAPER" --transition-type "$CHOSEN_TYPE" --transition-duration 3.0 --transition-fps 60 --transition-step 90 --transition-angle "$CHOSEN_ANGLE"
fi

exit 0
